---
/**
 * Top nav — brand on the left, page links + theme toggle on the right.
 * Theme toggle wiring lives in src/scripts/profiler.client.ts so it
 * isn't reimplemented per page.
 *
 * Resume is an HTML page (/resume) rather than a direct PDF link; the
 * page itself surfaces a "Download PDF" button to profile.resumeUrl.
 */
// `resume` link hidden for now — the /resume page still exists and is
// reachable by URL, just not linked from the nav.
const links = [
  { href: '/writing', label: 'writing' },
] as const;
---

<nav class="site-nav">
  <a class="brand" href="/">sarthak consul</a>
  <div class="links">
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
    <button class="theme-toggle" id="themeToggle" aria-label="cycle theme: auto / light / dark">[auto]</button>
  </div>
</nav>
