---
/**
 * Card — base wrapper used by every bento tile. Provides the consistent
 * label header, badge slot, body slot, and bottom meta line. Each
 * specific card (Featured, Focus, Writing, …) renders its own content
 * inside this wrapper.
 */

interface Props {
  /** Lowercase label shown after the `▸` marker. */
  label: string;
  /** Optional small badge in the top-right of the label row. */
  badge?: string;
  /** Badge color treatment — `accent` for emphasis, `subtle` for neutral. */
  badgeStyle?: 'accent' | 'subtle';
  /** Number of logical bento columns this card spans (1–4). Defaults to 1. */
  span?: 1 | 2 | 3 | 4;
  /** Optional one-liner shown in the dashed meta footer. */
  meta?: string;
  /**
   * If set, the meta footer becomes a clickable link to this URL.
   * External URLs (starting with `http`) open in a new tab.
   */
  metaHref?: string;
  /**
   * Optional extra CSS class on the root <article>. Used by Education
   * and Contact to opt into the sub-step grid spans (`span-1half`,
   * `span-half`); placed after the base span class so it overrides.
   */
  extraClass?: string;
}

const {
  label,
  badge,
  badgeStyle = 'accent',
  span = 1,
  meta,
  metaHref,
  extraClass,
} = Astro.props;

const isExternal = metaHref?.startsWith('http') ?? false;
---

<article class:list={['card', `span-${span}`, extraClass]}>
  <div class="label">
    <span class="label-text">{label}</span>
    {badge && (
      <span class:list={['badge', { 'badge-subtle': badgeStyle === 'subtle' }]}>
        {badge}
      </span>
    )}
  </div>

  <div class="body">
    <slot />
  </div>

  {meta && (
    metaHref ? (
      <a
        href={metaHref}
        class="meta meta-link"
        target={isExternal ? '_blank' : undefined}
        rel={isExternal ? 'noopener noreferrer' : undefined}
      >
        {meta}
      </a>
    ) : (
      <div class="meta">{meta}</div>
    )
  )}
</article>
