---
/** Tech stack — full list per category, mono-styled. */
import Card from '@components/Card.astro';
import { stack } from '@data/stack';
---

<Card label="stack" span={1} meta="~7y systems code">
  <ul class="stack-list">
    {stack.map((group) => (
      <li>
        <span class="stack-cat">{group.category}</span>
        <span class="stack-items">{group.items.join(' · ')}</span>
      </li>
    ))}
  </ul>
</Card>
