---
/** Featured-project card — the splat viewer (or whatever's `featured: true` in data). */
import Card from '@components/Card.astro';
import { featuredProject } from '@data/projects';

const proj = featuredProject();
if (!proj) throw new Error('FeaturedCard: no featured project in src/data/projects.ts');

const badge = proj.status === 'wip' ? 'WIP' : undefined;
/**
 * Compose a mono-styled tech summary for the meta footer. Splits the
 * tech tags into a language head + GPU stack rather than dumping them
 * all into one CSV.
 */
const langs = proj.tech.filter((t) => /^(Rust|Python|C\+\+|TypeScript)$/i.test(t));
const gpus  = proj.tech.filter((t) => /^(WGPU|CUDA|Metal|Vulkan|OpenGL)$/i.test(t));
const meta = `lang: ${langs.join('+').toLowerCase() || '—'} · gpu: ${gpus.join('+').toLowerCase() || '—'} · status: ${proj.status} · v0.1`;
---

<Card label="featured project" span={2} badge={badge} meta={meta}>
  <!--
    Visual area: SVG poster by default (works for non-WebGPU browsers).
    On a WebGPU-capable browser the client script below replaces this
    div's contents with an <iframe> that embeds the live /splat/
    viewer in `embed` mode.
  -->
  <div class="featured-visual" id="featuredVisual" aria-hidden="true"></div>

  <h3 class="card-title">
    {proj.url ? <a href={proj.url}>{proj.title}</a> : proj.title}
  </h3>
  <p class="card-text">{proj.description}</p>

  <!--
    "Launch viewer" CTA — opens the standalone fullscreen page.
    Hidden by default; revealed by the client script only on
    WebGPU-capable browsers so the button never leads to a dead end.
  -->
  <a id="splatLaunch" class="featured-cta" href="/splat/?scene=bonsai-7k.splat" hidden>
    ▶ Launch fullscreen
  </a>
</Card>

<script>
  // WebGPU feature detection. On a supporting browser:
  //   1. Replace the SVG poster with an <iframe> embedding /splat/ in
  //      embed mode — gives a live, interactive preview right in the
  //      card without polluting the home page's URL or pulling the
  //      WASM into the home bundle.
  //   2. Reveal the "Launch fullscreen" CTA underneath.
  //
  // On non-WebGPU browsers we do neither — the static SVG poster
  // remains and the CTA never appears.
  console.log('[featured] WebGPU:', 'gpu' in (globalThis.navigator ?? {}));
  if (typeof navigator !== 'undefined' && 'gpu' in navigator) {
    const visual = document.getElementById('featuredVisual');
    if (visual) {
      const iframe = document.createElement('iframe');
      iframe.src   = '/splat/?scene=bonsai-7k.splat&embed=1';
      iframe.title = 'Gaussian splat viewer (bonsai-7k)';
      // No `loading="lazy"` — the Featured card is above the fold so
      // lazy loading was unnecessarily delaying initialization in dev.
      iframe.allow = 'webgpu';        // explicit permission policy (no-op same-origin, defensive)
      iframe.setAttribute('scrolling', 'no');
      iframe.className = 'splat-iframe';
      visual.replaceChildren(iframe);
      visual.classList.add('live');
      console.log('[featured] iframe injected:', iframe.src);
    } else {
      console.warn('[featured] #featuredVisual not found');
    }
    document.getElementById('splatLaunch')?.removeAttribute('hidden');
  }
</script>
