---
/** Featured-project card — the splat viewer (or whatever's `featured: true` in data). */
import Card from '@components/Card.astro';
import { featuredProject } from '@data/projects';

const proj = featuredProject();
if (!proj) throw new Error('FeaturedCard: no featured project in src/data/projects.ts');

const badge = proj.status === 'wip' ? 'WIP' : undefined;
/**
 * Compose a mono-styled tech summary for the meta footer. Splits the
 * tech tags into a language head + GPU stack rather than dumping them
 * all into one CSV.
 */
const langs = proj.tech.filter((t) => /^(Rust|Python|C\+\+|TypeScript)$/i.test(t));
const gpus  = proj.tech.filter((t) => /^(WGPU|CUDA|Metal|Vulkan|OpenGL)$/i.test(t));
const meta = `lang: ${langs.join('+').toLowerCase() || '—'} · gpu: ${gpus.join('+').toLowerCase() || '—'} · status: ${proj.status} · v0.1`;
---

<Card label="featured project" span={2} badge={badge} meta={meta}>
  <!-- Static SVG poster — the home page no longer auto-loads the splat
       viewer. Users click "Launch fullscreen" below to open the live
       viewer on /splat/. -->
  <div class="featured-visual" aria-hidden="true"></div>

  <h3 class="card-title">
    {proj.url ? <a href={proj.url}>{proj.title}</a> : proj.title}
  </h3>
  <p class="card-text">{proj.description}</p>

  <!-- "Launch fullscreen" CTA. Hidden until the client script confirms
       WebGPU support, so users on non-WebGPU browsers don't see a
       button that leads to a dead end. -->
  <a id="splatLaunch" class="featured-cta" href="/splat/?scene=sutro_tower.spz" hidden>
    ▶ Launch fullscreen
  </a>
</Card>

<script>
  // WebGPU feature detection — reveals the "Launch fullscreen" CTA
  // AND kicks off a background prefetch of the splat assets so the
  // first /splat/ visit lands with everything already warm in the
  // browser's HTTP cache.
  //
  // Why prefetch is safe to do from /:
  //   - Triggered only on WebGPU-capable browsers (would have used
  //     them anyway), behind requestIdleCallback (browser idle), with
  //     a Save-Data respect-check (don't burn metered bandwidth).
  //   - The COOP/COEP service worker isn't active on the home page
  //     (its scope is /splat/), so prefetched responses land in the
  //     ordinary HTTP cache without COI wrapping. On the first /splat/
  //     visit the SW installs, intercepts the now-cached fetches and
  //     re-wraps them with the COOP/COEP/CORP headers it needs.
  if (typeof navigator !== 'undefined' && 'gpu' in navigator) {
    document.getElementById('splatLaunch')?.removeAttribute('hidden');

    const conn = navigator.connection;
    const saveData = conn?.saveData === true;
    const cellular = conn?.effectiveType && conn.effectiveType !== '4g';
    if (!saveData && !cellular) {
      const urls = [
        '/splat/sutro_tower.spz',
        '/splat/sutro_tower.spz.transform.txt',
        '/splat/pkg/gsplat_web.js',
        '/splat/pkg/gsplat_web_bg.wasm',
      ];
      const start = () => {
        for (const url of urls) {
          // `priority: 'low'` (Fetch Priority API, Chrome 102+) keeps
          // the prefetches behind any in-flight critical requests;
          // browsers that don't recognize it just queue at default.
          // `cache: 'force-cache'` populates the HTTP cache.
          fetch(url, { priority: 'low', cache: 'force-cache' })
            .catch(() => { /* prefetch is best-effort */ });
        }
      };
      if ('requestIdleCallback' in window) {
        requestIdleCallback(start, { timeout: 3000 });
      } else {
        setTimeout(start, 1500);
      }
    }
  }
</script>
