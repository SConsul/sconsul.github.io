---
/** Featured-project card — the splat viewer (or whatever's `featured: true` in data). */
import Card from '@components/Card.astro';
import { featuredProject } from '@data/projects';

const proj = featuredProject();
if (!proj) throw new Error('FeaturedCard: no featured project in src/data/projects.ts');

const badge = proj.status === 'wip' ? 'WIP' : undefined;
/**
 * Compose a mono-styled tech summary for the meta footer. Splits the
 * tech tags into a language head + GPU stack rather than dumping them
 * all into one CSV.
 */
const langs = proj.tech.filter((t) => /^(Rust|Python|C\+\+|TypeScript)$/i.test(t));
const gpus  = proj.tech.filter((t) => /^(WGPU|CUDA|Metal|Vulkan|OpenGL)$/i.test(t));
const meta = `lang: ${langs.join('+').toLowerCase() || '—'} · gpu: ${gpus.join('+').toLowerCase() || '—'} · status: ${proj.status} · v0.1`;
---

<Card label="featured project" span={2} badge={badge} meta={meta}>
  <div class="featured-visual" aria-hidden="true"></div>
  <h3 class="card-title">
    {proj.url ? <a href={proj.url}>{proj.title}</a> : proj.title}
  </h3>
  <p class="card-text">{proj.description}</p>
</Card>
