---
/** Experience — role list. Dates intentionally omitted on the home card
    (the resume PDF carries the full timeline). */
import Card from '@components/Card.astro';
import { experience } from '@data/experience';
---

<Card label="experience" span={2}>
  <div class="exp-list">
    {experience.map((r) => (
      <div class="exp-row">
        <div class="lhs">
          <div class="role">
            <strong>{r.company}</strong>
            <span class="sep">·</span>
            {r.title}
          </div>
          <div class="loc">{r.location}</div>
        </div>
      </div>
    ))}
  </div>
</Card>
