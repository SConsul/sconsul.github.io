---
/** Experience — role list with right-aligned date ranges. */
import Card from '@components/Card.astro';
import { experience } from '@data/experience';

/** "2023-04" → "Apr '23". Returns "now" for the `null` sentinel. */
function fmt(iso: string | null): string {
  if (!iso) return 'now';
  const [yyyy, mm] = iso.split('-') as [string, string];
  const months = ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'];
  return `${months[parseInt(mm, 10) - 1]} '${yyyy.slice(2)}`;
}
---

<Card label="experience" span={2} meta="full resume →" metaHref="/resume">
  <div class="exp-list">
    {experience.map((r) => (
      <div class="exp-row">
        <div class="lhs">
          <div class="role">
            <strong>{r.company}</strong>
            <span class="sep">·</span>
            {r.title}
          </div>
          <div class="loc">{r.location}</div>
        </div>
        <div class="rhs">{fmt(r.start)} — {fmt(r.end)}</div>
      </div>
    ))}
  </div>
</Card>
