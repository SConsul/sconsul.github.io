---
/** Experience — role list with right-aligned date ranges. */
import Card from '@components/Card.astro';
import { experience } from '@data/experience';
import { shortMonthYear } from '@utils/format';
---

<Card label="experience" span={2}>
  <div class="exp-list">
    {experience.map((r) => (
      <div class="exp-row">
        <div class="lhs">
          <div class="role">
            <strong>{r.company}</strong>
            <span class="sep">·</span>
            {r.title}
          </div>
          <div class="loc">{r.location}</div>
        </div>
        <div class="rhs">{shortMonthYear(r.start)} — {shortMonthYear(r.end)}</div>
      </div>
    ))}
  </div>
</Card>
