---
/**
 * Writing — placeholder card. The MDX content under
 * src/content/writing/ is all stubs ("coming soon" + an outline), so
 * the home card collapses to a single muted "drafts in progress"
 * line. The card still reads the collection so the badge reflects the
 * real draft count.
 *
 * The /writing index and per-post pages have been removed too — no
 * `meta` / `metaHref` to link to from the card footer.
 *
 * To restore the post listing: revert the body to a `.writing-list`
 * mapping over `posts` and re-add `src/pages/writing/index.astro` +
 * `src/pages/writing/[...slug].astro`. The dead `.writing-list` /
 * `.writing-item` CSS in global.css is still there.
 */
import Card from '@components/Card.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing')).filter((p) => !p.data.draft);
const badge = `${posts.length} draft${posts.length === 1 ? '' : 's'}`;
---

<Card
  label="writing"
  span={2}
  badge={badge}
  badgeStyle="subtle"
>
  <div class="writing-empty">drafts in progress</div>
</Card>
