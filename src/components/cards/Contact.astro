---
/**
 * Contact — icon-only row. Each icon links to its channel; destination
 * is communicated via the title attribute (OS tooltip + screen-reader
 * announcement).
 */
import Card from '@components/Card.astro';
import Icon from '@components/Icon.astro';
import { profile } from '@data/profile';

type IconName = 'email' | 'github' | 'linkedin' | 'scholar';

interface ContactLink {
  readonly icon: IconName;
  readonly title: string;
  readonly href: string;
  readonly external: boolean;
}

const links: readonly ContactLink[] = [
  { icon: 'email',    title: `email · ${profile.email}`, href: `mailto:${profile.email}`,                      external: false },
  { icon: 'github',   title: 'github',                   href: `https://github.com/${profile.github}`,        external: true  },
  { icon: 'linkedin', title: 'linkedin',                 href: `https://linkedin.com/in/${profile.linkedin}`, external: true  },
  { icon: 'scholar',  title: 'google scholar',           href: profile.scholar,                                external: true  },
];
---

<Card label="contact" span={2}>
  <div class="contact-row">
    {links.map((l) => (
      <a
        href={l.href}
        target={l.external ? '_blank' : undefined}
        rel={l.external ? 'noopener noreferrer' : undefined}
        title={l.title}
        aria-label={l.title}
        class="contact-icon-btn"
      >
        <Icon name={l.icon} size={18} ariaLabel={l.title} />
      </a>
    ))}
  </div>
</Card>
