---
/**
 * /splat — fullscreen WebGPU Gaussian-splat viewer.
 *
 * Why an Astro page (not a static `public/splat/index.html`):
 *   The Astro / Vite dev server doesn't auto-resolve a trailing-slash
 *   URL like `/splat/` to `public/splat/index.html` (this works in the
 *   built site because GitHub Pages serves directory indexes, but
 *   `npm run dev` 404s). An Astro page at this route always resolves.
 *
 * Other assets (compiled WASM + JS glue + scene file) still live in
 * `public/splat/` and are fetched at runtime from `/splat/pkg/...` and
 * `/splat/<scene>`. The Rust source for gsplat_rs is NOT in this repo.
 *
 * The <script> below MUST be `is:inline`: Vite would otherwise try to
 * resolve the dynamic import `./pkg/gsplat_web.js` against the .astro
 * source file at build time (and fail). `is:inline` tells Astro to
 * emit the script verbatim — the browser runs it at runtime, where
 * the relative path resolves correctly against the page URL `/splat/`.
 */
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>splat viewer · sarthak consul</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="noindex" />
    <style>
      html, body {
        margin: 0; padding: 0; height: 100%;
        background: #000;
        overflow: hidden;
        color: #ddd;
        font: 13px/1.4 'JetBrains Mono', ui-monospace, monospace;
      }
      canvas#gsplat-canvas {
        display: block;
        width: 100vw; height: 100vh;
        outline: none;
      }

      .home-link {
        position: fixed;
        top: 14px; left: 14px;
        color: rgba(220, 220, 220, 0.7);
        background: rgba(0, 0, 0, 0.45);
        padding: 6px 12px;
        border-radius: 4px;
        text-decoration: none;
        font-size: 12px;
        transition: color 150ms, background 150ms;
        z-index: 10;
      }
      .home-link:hover {
        color: #fff;
        background: rgba(0, 0, 0, 0.7);
      }

      #status {
        position: fixed;
        top: 14px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(0, 0, 0, 0.6);
        padding: 8px 14px;
        border-radius: 4px;
        max-width: 70vw;
        pointer-events: none;
        font-size: 12px;
        z-index: 10;
      }
      #status.hidden { display: none; }
      #status.error {
        background: rgba(160, 0, 0, 0.75);
        pointer-events: auto;
      }
      #status code {
        background: rgba(255, 255, 255, 0.08);
        padding: 1px 4px;
        border-radius: 3px;
        font-family: inherit;
      }

      .fallback {
        position: fixed;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 24px;
        color: #bbb;
      }
      .fallback h1 {
        font-size: 20px;
        color: #fff;
        margin: 0 0 12px;
        letter-spacing: -0.01em;
      }
      .fallback p { margin: 6px 0; max-width: 460px; }
      .fallback a { color: #6aaeff; }
      .fallback code {
        background: rgba(255, 255, 255, 0.08);
        padding: 1px 5px;
        border-radius: 3px;
      }
      .hidden { display: none !important; }

      /* Embed mode (when iframed into the home page): strip the chrome
         so it looks like a live preview, not a navigable page. */
      body.embed .home-link { display: none; }
      body.embed #status {
        top: 8px;
        font-size: 10px;
        padding: 4px 8px;
      }
    </style>
  </head>
  <body>
    <a href="/" class="home-link" aria-label="back to home">← home</a>

    <canvas id="gsplat-canvas" tabindex="0"></canvas>
    <div id="status">loading…</div>

    <!-- Shown only when navigator.gpu is missing (WebGPU unsupported). -->
    <div id="fallback" class="fallback hidden">
      <h1>WebGPU not available</h1>
      <p>
        This viewer is WebGPU-only. Open in Chrome / Edge 113+, or
        Safari Tech Preview, or Firefox Nightly with
        <code>dom.webgpu.enabled</code>.
      </p>
      <p><a href="/">← back to home</a></p>
    </div>

    <script is:inline type="module">
      const canvas   = document.getElementById('gsplat-canvas');
      const status   = document.getElementById('status');
      const fallback = document.getElementById('fallback');
      let   params   = new URLSearchParams(window.location.search);

      // Embed mode (iframed into the home page) hides the home link
      // and shrinks the status banner. Triggered by ?embed=1.
      if (params.has('embed')) {
        document.body.classList.add('embed');
      }

      // The WASM reads `?scene=…` directly from window.location.search
      // — it doesn't consume any JS variable we'd pass in. If the URL
      // doesn't carry a scene, rewrite the URL via replaceState BEFORE
      // we call init() so the WASM finds it.
      if (!params.has('scene')) {
        const u = new URL(window.location.href);
        u.searchParams.set('scene', 'bonsai-7k.splat');
        history.replaceState(null, '', u);
        params = new URLSearchParams(window.location.search);
      }
      const scene = params.get('scene');

      // Keep the canvas backing buffer in sync with its visible CSS size.
      function sizeCanvas() {
        const dpr = window.devicePixelRatio || 1;
        const w = Math.max(1, Math.floor(canvas.clientWidth  * dpr));
        const h = Math.max(1, Math.floor(canvas.clientHeight * dpr));
        if (canvas.width  !== w) canvas.width  = w;
        if (canvas.height !== h) canvas.height = h;
      }
      sizeCanvas();
      new ResizeObserver(sizeCanvas).observe(canvas);
      window.addEventListener('resize', sizeCanvas);

      if (!('gpu' in navigator)) {
        status.classList.add('hidden');
        canvas.classList.add('hidden');
        fallback.classList.remove('hidden');
      } else {
        status.textContent = 'loading ' + scene + '…';
        canvas.focus(); // give TAB / arrow keys to the viewer's profiler

        // Wait for the canvas to have real (non-zero) dimensions before
        // calling init(). When this page is iframed, layout hasn't run
        // by the time the script executes — `canvas.clientWidth` is 0,
        // we'd clamp to 1px, and the viewer's `Orbit::from_bbox(aspect)`
        // would initialize for a 1:1 frame. ResizeObserver later grows
        // the canvas but the initial orbit is already baked in, so the
        // scene appears wrongly framed. The fullscreen page never hits
        // this because the window has its real size before scripts run.
        function waitForCanvasSize() {
          return new Promise((resolve) => {
            if (canvas.clientWidth > 0 && canvas.clientHeight > 0) {
              resolve();
              return;
            }
            const ro = new ResizeObserver(() => {
              if (canvas.clientWidth > 0 && canvas.clientHeight > 0) {
                ro.disconnect();
                resolve();
              }
            });
            ro.observe(canvas);
            // Safety net: don't wait forever — if for some reason the
            // canvas never gets a size (display:none etc.), give up
            // after 2s and let init use whatever's there.
            setTimeout(() => { ro.disconnect(); resolve(); }, 2000);
          });
        }

        waitForCanvasSize()
          .then(() => {
            sizeCanvas(); // ensure backing buffer matches the now-known CSS size
            return import('./pkg/gsplat_web.js');
          })
          .then(({ default: init }) => init())
          .then(() => {
            setTimeout(() => status.classList.add('hidden'), 1200);
          })
          .catch((err) => {
            status.classList.add('error');
            status.textContent = 'error: ' + (err && err.message ? err.message : String(err));
            console.error(err);
          });
      }
    </script>
  </body>
</html>
