---
/**
 * /resume — header + embedded PDF viewer.
 *
 * The previous version of this page re-rendered the resume data as
 * HTML; it always risked drifting from main.tex / public/resume.pdf.
 * Embedding the PDF directly keeps the canonical artifact (the PDF
 * built from main.tex) as the single source of truth.
 *
 * The `<object>` element gives us a real fallback for browsers that
 * can't render PDFs inline (a "Download" link) — `<iframe>` would
 * just render blank.
 */
import Base from '@/layouts/Base.astro';
import Nav from '@components/Nav.astro';
import Profiler from '@components/Profiler.astro';
import { profile } from '@data/profile';
---

<Base
  title="Resume — Sarthak Consul"
  description="Resume of Sarthak Consul — ML systems engineer."
>
  <div class="container resume-container">
    <Nav />

    <header class="resume-head">
      <h1>{profile.name} <span class="sub">— resume</span></h1>
      <a href={profile.resumeUrl} class="download" download>↓ Download PDF</a>
    </header>

    <object
      data={profile.resumeUrl}
      type="application/pdf"
      class="pdf-embed"
      aria-label="Resume PDF"
    >
      <div class="pdf-fallback">
        <p>Your browser can't display PDFs inline.</p>
        <a href={profile.resumeUrl} download>↓ Download the PDF</a>
      </div>
    </object>
  </div>

  <Profiler />
</Base>

<style>
  .resume-container { max-width: 1000px; }

  .resume-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 20px;
  }
  .resume-head h1 {
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .resume-head .sub {
    color: var(--fg-muted);
    font-weight: 400;
  }
  .download {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 7px 14px;
    border-radius: 4px;
    text-decoration: none;
    transition: background 150ms, color 150ms;
    white-space: nowrap;
  }
  .download:hover {
    background: var(--accent);
    color: var(--bg);
  }

  .pdf-embed {
    width: 100%;
    /* Use up the rest of the viewport, with a sensible floor. The
       56px bottom space leaves room for the profiler slim bar; the
       header is ~80px on desktop. */
    height: calc(100vh - 220px);
    min-height: 640px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: #fff;
    margin-bottom: 24px;
  }

  /* Shown only when the browser can't render the embedded PDF. */
  .pdf-fallback {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 60px 20px;
    text-align: center;
    color: var(--fg-muted);
  }
  .pdf-fallback a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--accent);
  }

  @media (max-width: 600px) {
    .resume-head {
      flex-direction: column;
      align-items: flex-start;
    }
    .pdf-embed {
      height: calc(100vh - 260px);
      min-height: 480px;
    }
  }
</style>
